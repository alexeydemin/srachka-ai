{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "issues", "required_fixes", "done_enough"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["accept", "reject", "ask_user"]
    },
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "required_fixes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "done_enough": {
      "type": "boolean"
    }
  }
}
